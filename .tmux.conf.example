# Mouse support
set -g mouse on

# Enable OSC 52 clipboard passthrough
# Required for nvim clipboard over SSH to work inside tmux
set -g set-clipboard on

# Faster escape key response (helps with nvim)
set-option -sg escape-time 10

# Enable focus events for nvim
set-option -g focus-events on

# Terminal settings
set-option -g default-terminal "screen-256color"
set-option -sa terminal-overrides ",xterm-256color:RGB"

# Copy mode: use xclip for clipboard integration
bind -T copy-mode-vi Enter send-keys -X copy-pipe-and-cancel 'xclip -sel clip -i'
